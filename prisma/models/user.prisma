model User {
  id Int @id @default(autoincrement())

  email String? @unique

  name String?

  password_hash String?

  phone String? @unique

  role Role @default(USER)

  created_at DateTime @default(now())

  orders  Order[]
  reviews Review[]

  addresses Address[]
  cartItems CartItem[]
  wishlist  WishlistItem[]

  accounts  Account[]
  sessions  Session[]
  otpTokens OtpToken[]

  notificationStates NotificationRecipient[]
}

enum Role {
  USER
  ADMIN
}
